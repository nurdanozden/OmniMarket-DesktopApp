<Window x:Class="OmniMarket.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OmniMarket.ViewModels"
        xmlns:views="clr-namespace:OmniMarket.Views"
        Title="OmniMarket – Akıllı Market Depo Yönetimi"
        Height="750" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SpaceBackground}"
        FontFamily="Poppins">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductListViewModel}">
            <views:ProductListView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SupplierListViewModel}">
            <views:SupplierListView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogListViewModel}">
            <views:LogListView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView DataContext="{Binding}"/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource WoodSidebarBackground}" BorderBrush="#F59E0B" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo Section -->
                <StackPanel Grid.Row="0" Margin="20,24,20,24">
                    <TextBlock Text="🛒" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="OmniMarket" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentMarket.Name}" FontSize="12"
                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <Border Height="1" Background="#FCD34D" Margin="0,20,0,0"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1" Margin="12,0">
                    <Button Content="📊  Dashboard" Command="{Binding ShowDashboardCommand}"
                            Style="{StaticResource SidebarButton}"/>
                    <Button Content="📦  Ürünler" Command="{Binding ShowProductsCommand}"
                            Style="{StaticResource SidebarButton}"/>
                    <Button Content="🔗  Tedarikçiler" Command="{Binding ShowSuppliersCommand}"
                            Style="{StaticResource SidebarSupplierButton}"/>
                    <Button Content="⚙️  Ayarlar" Command="{Binding ShowSettingsCommand}"
                            Style="{StaticResource SidebarSettingsButton}"/>
                    <Button Content="🌸  İşlem Geçmişi" Command="{Binding ShowLogsCommand}"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"
                            Style="{StaticResource SidebarLogButton}"/>
                </StackPanel>

                <!-- Logout -->
                <StackPanel Grid.Row="2" Margin="12,0,12,20">
                    <Border Height="1" Background="#FCD34D" Margin="0,0,0,16"/>
                    <Button Content="🚪  Çıkış Yap" Command="{Binding LogoutCommand}"
                            Style="{StaticResource SidebarButton}" Foreground="#F97316"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Border Grid.Column="1" Background="Transparent" ClipToBounds="True">
            <ContentControl Content="{Binding CurrentView}"/>
        </Border>
    </Grid>
</Window>
