<Window x:Class="OmniMarket.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OmniMarket.ViewModels"
        xmlns:views="clr-namespace:OmniMarket.Views"
        Title="OmniMarket – Akıllı Market Depo Yönetimi"
        Height="750" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0f172a">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductListViewModel}">
            <views:ProductListView DataContext="{Binding}"/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1e293b">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo Section -->
                <StackPanel Grid.Row="0" Margin="20,24,20,24">
                    <TextBlock Text="🛒" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="OmniMarket" FontSize="22" FontWeight="Bold"
                               Foreground="#f8fafc" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentMarket.Name}" FontSize="12"
                               Foreground="#64748b" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <Border Height="1" Background="#334155" Margin="0,20,0,0"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1" Margin="12,0">
                    <Button Content="📊  Dashboard" Command="{Binding ShowDashboardCommand}"
                            Style="{StaticResource SidebarButton}"/>
                    <Button Content="📦  Ürünler" Command="{Binding ShowProductsCommand}"
                            Style="{StaticResource SidebarButton}"/>
                </StackPanel>

                <!-- Logout -->
                <StackPanel Grid.Row="2" Margin="12,0,12,20">
                    <Border Height="1" Background="#334155" Margin="0,0,0,16"/>
                    <Button Content="🚪  Çıkış Yap" Command="{Binding LogoutCommand}"
                            Style="{StaticResource SidebarButton}" Foreground="#ef4444"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Border Grid.Column="1" Background="#0f172a">
            <ContentControl Content="{Binding CurrentView}"/>
        </Border>
    </Grid>
</Window>
