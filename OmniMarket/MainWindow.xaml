<Window x:Class="OmniMarket.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OmniMarket.ViewModels"
        xmlns:views="clr-namespace:OmniMarket.Views"
        Title="OmniMarket – Akıllı Market Depo Yönetimi"
        Height="750" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SpaceBackground}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductListViewModel}">
            <views:ProductListView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SupplierListViewModel}">
            <views:SupplierListView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SupplierDetailViewModel}">
            <views:SupplierDetailView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogListViewModel}">
            <views:LogListView DataContext="{Binding}"/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView DataContext="{Binding}"/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar (Slate-900 dark) ── -->
        <Border Grid.Column="0" Background="{StaticResource CorpSidebar}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Margin="20,28,20,20">
                    <!-- Icon row -->
                    <Border Width="48" Height="48" Background="#1E293B" CornerRadius="12"
                            HorizontalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock Text="📦" FontSize="26"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="OmniMarket" FontSize="20" FontWeight="Bold"
                               Foreground="#F1F5F9" HorizontalAlignment="Center"
                               FontFamily="Segoe UI"/>
                    <TextBlock Text="{Binding CurrentMarket.Name}" FontSize="12"
                               Foreground="#64748B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <!-- Divider -->
                    <Border Height="1" Background="#1E293B" Margin="0,18,0,0" CornerRadius="1"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1" Margin="12,4">
                    <Button Command="{Binding ShowDashboardCommand}"
                            Style="{StaticResource SidebarButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▦" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ShowProductsCommand}"
                            Style="{StaticResource SidebarButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◫" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Ürünler" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ShowSuppliersCommand}"
                            Style="{StaticResource SidebarSupplierButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⊞" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Tedarikçiler" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ShowSettingsCommand}"
                            Style="{StaticResource SidebarSettingsButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Ayarlar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ShowLogsCommand}"
                            Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"
                            Style="{StaticResource SidebarLogButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="≡" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="İşlem Geçmişi" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Logout -->
                <StackPanel Grid.Row="2" Margin="12,0,12,20">
                    <Border Height="1" Background="#1E293B" Margin="0,0,0,12" CornerRadius="1"/>
                    <Button Command="{Binding LogoutCommand}"
                            Style="{StaticResource SidebarButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="→" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"
                                       Foreground="#F87171"/>
                            <TextBlock Text="Çıkış Yap" Foreground="#F87171" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Border Grid.Column="1" Background="Transparent" ClipToBounds="True">
            <ContentControl Content="{Binding CurrentView}"/>
        </Border>
    </Grid>
</Window>
