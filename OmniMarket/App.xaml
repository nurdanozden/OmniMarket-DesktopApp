<Application x:Class="OmniMarket.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:OmniMarket.Helpers">
    <Application.Resources>
        <!-- ===== Converters ===== -->
        <helpers:ExpiryStatusConverter x:Key="ExpiryStatusColor"/>
        <helpers:ExpiryStatusTextConverter x:Key="ExpiryStatusText"/>
        <helpers:StockWarningConverter x:Key="StockWarningColor"/>
        <helpers:CategoryToEmojiConverter x:Key="CategoryEmoji"/>
        <helpers:HexStringToBrushConverter x:Key="HexToBrush"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <helpers:StringToVisibilityConverter x:Key="StringToVisibility"/>
        <helpers:ZeroToVisibilityConverter x:Key="ZeroToVisibility"/>

        <!-- ===== Corporate Color Palette ===== -->
        <!-- Backgrounds -->
        <SolidColorBrush x:Key="CorpBackground"   Color="#F1F5F9"/>  <!-- Slate-100 content bg -->
        <SolidColorBrush x:Key="CorpSurface"      Color="#FFFFFF"/>  <!-- Card surface -->
        <SolidColorBrush x:Key="CorpSidebar"      Color="#0F172A"/>  <!-- Slate-900 sidebar -->
        <SolidColorBrush x:Key="CorpSidebarHover" Color="#1E293B"/>  <!-- Slate-800 hover -->

        <!-- Accent Colors -->
        <SolidColorBrush x:Key="CorpBlue"    Color="#1D4ED8"/>  <!-- Dashboard Blue -->
        <SolidColorBrush x:Key="CorpBlueSoft" Color="#DBEAFE"/> <!-- Blue-100 backgrounds -->
        <SolidColorBrush x:Key="CorpEmerald" Color="#059669"/>  <!-- Emerald-600 success -->
        <SolidColorBrush x:Key="CorpEmeraldSoft" Color="#D1FAE5"/> <!-- Emerald-100 -->
        <SolidColorBrush x:Key="CorpAmber"   Color="#D97706"/>  <!-- Amber warning -->
        <SolidColorBrush x:Key="CorpAmberSoft" Color="#FEF3C7"/> <!-- Amber-100 -->
        <SolidColorBrush x:Key="CorpRed"     Color="#DC2626"/>  <!-- Red danger -->
        <SolidColorBrush x:Key="CorpRedSoft" Color="#FEE2E2"/>  <!-- Red-100 -->
        <SolidColorBrush x:Key="CorpSlate"   Color="#475569"/>  <!-- Slate-600 secondary -->

        <!-- Legacy aliases (used throughout views) -->
        <SolidColorBrush x:Key="AccentPrimary" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#1D4ED8"/>
        <SolidColorBrush x:Key="AccentGreen"   Color="#059669"/>
        <SolidColorBrush x:Key="AccentOrange"  Color="#D97706"/>
        <SolidColorBrush x:Key="AccentPink"    Color="#DC2626"/>  <!-- remapped to red -->
        <SolidColorBrush x:Key="TextPrimary"   Color="#0F172A"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#64748B"/>
        <SolidColorBrush x:Key="PastelGreen"   Color="#D1FAE5"/>
        <SolidColorBrush x:Key="PastelBlue"    Color="#DBEAFE"/>
        <SolidColorBrush x:Key="CreamPanel"    Color="#F8FAFC"/>

        <!-- Main content background -->
        <LinearGradientBrush x:Key="SpaceBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F1F5F9" Offset="0"/>
            <GradientStop Color="#E2E8F0" Offset="1"/>
        </LinearGradientBrush>

        <!-- Sidebar solid dark -->
        <SolidColorBrush x:Key="WoodSidebarBackground" Color="#0F172A"/>

        <!-- ===== Shadow Effects ===== -->
        <DropShadowEffect x:Key="CardShadow"  BlurRadius="20" Direction="270"
                          ShadowDepth="6" Opacity="0.10" Color="#1E293B"/>
        <DropShadowEffect x:Key="GlowBlue"    BlurRadius="10" ShadowDepth="0" Color="#3B82F6" Opacity="0.5"/>
        <DropShadowEffect x:Key="GlowRed"     BlurRadius="12" ShadowDepth="0" Color="#DC2626" Opacity="0.4"/>
        <DropShadowEffect x:Key="GlowGreen"   BlurRadius="10" ShadowDepth="0" Color="#059669" Opacity="0.5"/>
        <DropShadowEffect x:Key="GlowAmber"   BlurRadius="10" ShadowDepth="0" Color="#D97706" Opacity="0.5"/>
        <DropShadowEffect x:Key="GlowOrange"  BlurRadius="12" ShadowDepth="0" Color="#D97706" Opacity="0.6"/>
        <DropShadowEffect x:Key="GlowPurple"  BlurRadius="10" ShadowDepth="0" Color="#6D28D9" Opacity="0.4"/>

        <!-- Card Panel -->
        <Style x:Key="GlassmorphismPanel" TargetType="Border">
            <Setter Property="Background"       Value="#FFFFFF"/>
            <Setter Property="BorderBrush"      Value="#E2E8F0"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="16"/>
        </Style>

        <!-- ===== ModernTextBox ===== -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background"       Value="#F8FAFC"/>
            <Setter Property="Foreground"       Value="#0F172A"/>
            <Setter Property="CaretBrush"       Value="{StaticResource AccentBlue}"/>
            <Setter Property="BorderBrush"      Value="#CBD5E1"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="12,9"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <TextBlock Text="{TemplateBinding Tag}" Foreground="#94A3B8"
                                           VerticalAlignment="Center" FontSize="12"
                                           Visibility="{Binding Text.IsEmpty, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibility}}"/>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"  Value="#1D4ED8"/>
                                <Setter TargetName="Bd" Property="Background"   Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ModernPasswordBox ===== -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background"       Value="#F8FAFC"/>
            <Setter Property="Foreground"       Value="#0F172A"/>
            <Setter Property="CaretBrush"       Value="{StaticResource AccentBlue}"/>
            <Setter Property="BorderBrush"      Value="#CBD5E1"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="12,9"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1D4ED8"/>
                                <Setter TargetName="Bd" Property="Background"  Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ModernComboBox ===== -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background"      Value="#F8FAFC"/>
            <Setter Property="Foreground"      Value="#0F172A"/>
            <Setter Property="BorderBrush"     Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground"  Value="#0F172A"/>
                        <Setter Property="Background"  Value="#FFFFFF"/>
                        <Setter Property="Padding"     Value="10,6"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                                <Setter Property="Foreground" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#BFDBFE"/>
                                <Setter Property="Foreground" Value="#1D4ED8"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ModernDatePicker ===== -->
        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Background"      Value="#F8FAFC"/>
            <Setter Property="Foreground"      Value="#0F172A"/>
            <Setter Property="BorderBrush"     Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
        </Style>

        <!-- ===== Button Base ===== -->
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="16,9"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.90"/>
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="1.02" ScaleY="1.02"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.80"/>
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.98" ScaleY="0.98"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary (Blue) -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>

        <!-- Success (Emerald) -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#059669"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>

        <!-- Warning (Amber) -->
        <Style x:Key="WarningButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#D97706"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>

        <!-- Danger (Red) -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>

        <!-- Secondary -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Foreground" Value="#475569"/>
        </Style>

        <!-- Small (chip-like) -->
        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#DBEAFE"/>
            <Setter Property="Foreground" Value="#1D4ED8"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Padding"    Value="10,5"/>
        </Style>

        <!-- CuteButton → now professional primary -->
        <Style x:Key="CuteButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#1D4ED8"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding"    Value="16,10"/>
        </Style>

        <!-- ===== Sidebar Button (dark sidebar) ===== -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background"                Value="Transparent"/>
            <Setter Property="Foreground"                Value="#94A3B8"/>
            <Setter Property="FontSize"                  Value="14"/>
            <Setter Property="Padding"                   Value="14,11"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"                    Value="Hand"/>
            <Setter Property="FontFamily"                Value="Segoe UI"/>
            <Setter Property="BorderThickness"           Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}" Margin="0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="Indicator" Grid.Column="0" Width="3" Height="18"
                                            Background="#1D4ED8" CornerRadius="2" Margin="-6,0,10,0" Opacity="0"/>
                                    <ContentPresenter Grid.Column="1"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="#E2E8F0"/>
                                <Setter TargetName="Indicator" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#334155"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Supplier sidebar btn — same as main -->
        <Style x:Key="SidebarSupplierButton" TargetType="Button" BasedOn="{StaticResource SidebarButton}"/>

        <!-- Logs sidebar btn -->
        <Style x:Key="SidebarLogButton" TargetType="Button" BasedOn="{StaticResource SidebarButton}"/>

        <!-- Settings sidebar btn -->
        <Style x:Key="SidebarSettingsButton" TargetType="Button" BasedOn="{StaticResource SidebarButton}"/>

        <!-- Test / Demo Button -->
        <Style x:Key="TestButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#D97706"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding"    Value="16,10"/>
        </Style>
    </Application.Resources>
</Application>
