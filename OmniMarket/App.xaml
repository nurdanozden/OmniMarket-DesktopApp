<Application x:Class="OmniMarket.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:OmniMarket.Helpers">
    <Application.Resources>
        <!-- ===== Converters ===== -->
        <helpers:ExpiryStatusConverter x:Key="ExpiryStatusColor"/>
        <helpers:ExpiryStatusTextConverter x:Key="ExpiryStatusText"/>
        <helpers:StockWarningConverter x:Key="StockWarningColor"/>
        <helpers:CategoryToEmojiConverter x:Key="CategoryEmoji"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <!-- String to Visibility (show if non-empty) -->
        <helpers:StringToVisibilityConverter x:Key="StringToVisibility"/>
        <!-- Zero count to Visibility (show if zero) -->
        <helpers:ZeroToVisibilityConverter x:Key="ZeroToVisibility"/>

        <!-- ===== Soft Market Kasabasi Colors ===== -->
        <SolidColorBrush x:Key="PastelGreen" Color="#ECFDF5"/>
        <SolidColorBrush x:Key="PastelBlue" Color="#F0F9FF"/>
        <SolidColorBrush x:Key="CreamPanel" Color="#FEFCE8"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#3B82F6"/>
        <SolidColorBrush x:Key="AccentPrimary" Color="#3B82F6"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#F97316"/>
        <SolidColorBrush x:Key="AccentPink" Color="#F472B6"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#374151"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>

        <!-- Soft pastel background -->
        <LinearGradientBrush x:Key="SpaceBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFEDFA" Offset="0"/>
            <GradientStop Color="#FFF2E8" Offset="0.5"/>
            <GradientStop Color="#EAF2FF" Offset="1"/>
        </LinearGradientBrush>

        <!-- Sidebar cute background -->
        <LinearGradientBrush x:Key="WoodSidebarBackground" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FBCFE8" Offset="0"/>
            <GradientStop Color="#FCE7F3" Offset="0.5"/>
            <GradientStop Color="#FDF2F8" Offset="1"/>
        </LinearGradientBrush>

        <!-- ===== Shadow Effects ===== -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="25" Direction="270"
                          ShadowDepth="8" Opacity="0.15" Color="#F472B6"/>

        <DropShadowEffect x:Key="GlowBlue" BlurRadius="10" ShadowDepth="0" Color="#93C5FD" Opacity="0.6"/>
        <DropShadowEffect x:Key="GlowRed" BlurRadius="12" ShadowDepth="0" Color="#F9A8D4" Opacity="0.6"/>
        <DropShadowEffect x:Key="GlowGreen" BlurRadius="10" ShadowDepth="0" Color="#6EE7B7" Opacity="0.6"/>
        <DropShadowEffect x:Key="GlowAmber" BlurRadius="10" ShadowDepth="0" Color="#FCD34D" Opacity="0.6"/>
        <DropShadowEffect x:Key="GlowOrange" BlurRadius="12" ShadowDepth="0" Color="#FDBA74" Opacity="0.7"/>
        <DropShadowEffect x:Key="GlowPurple" BlurRadius="10" ShadowDepth="0" Color="#C4B5FD" Opacity="0.6"/>

        <!-- Glassmorphism Panel Style -->
        <Style x:Key="GlassmorphismPanel" TargetType="Border">
            <Setter Property="Background" Value="#E6FFFFFF"/>
            <Setter Property="BorderBrush" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="CornerRadius" Value="24"/>
        </Style>

        <!-- ===== ModernTextBox ===== -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentGreen}"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Poppins"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <TextBlock Text="{TemplateBinding Tag}" Foreground="#9CA3AF"
                                           VerticalAlignment="Center" FontSize="12"
                                           Visibility="{Binding Text.IsEmpty, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVisibility}}"/>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="Bd" Property="Effect" Value="{StaticResource GlowBlue}"/>
                                <Setter TargetName="Bd" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ModernPasswordBox ===== -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentGreen}"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Poppins"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="Bd" Property="Effect" Value="{StaticResource GlowBlue}"/>
                                <Setter TargetName="Bd" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ModernComboBox ===== -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Poppins"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#374151"/>
                        <Setter Property="Background" Value="#F9FAFB"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DBEAFE"/>
                                <Setter Property="Foreground" Value="#1F2937"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#BFDBFE"/>
                                <Setter Property="Foreground" Value="#1F2937"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ModernDatePicker ===== -->
        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Poppins"/>
        </Style>

        <!-- ===== Button Base ===== -->
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Poppins"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="20" Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.04" ScaleY="1.04"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary (Blue) -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{DynamicResource AccentPrimary}"/>
            <Setter Property="Foreground" Value="#ffffff"/>
        </Style>

        <!-- Success (Green) -->
        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="#ffffff"/>
        </Style>

        <!-- Warning (Orange) -->
        <Style x:Key="WarningButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#F97316"/>
            <Setter Property="Foreground" Value="#ffffff"/>
        </Style>

        <!-- Danger (Pink) -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#F472B6"/>
            <Setter Property="Foreground" Value="#ffffff"/>
        </Style>

        <!-- Secondary (Soft outline) -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#374151"/>
        </Style>

        <!-- Small Button -->
        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#DBEAFE"/>
            <Setter Property="Foreground" Value="#1D4ED8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>

        <!-- Cute Button -->
        <Style x:Key="CuteButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F472B6" Offset="0"/>
                        <GradientStop Color="#EC4899" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Heavy"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Sidebar Button -->
        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Poppins"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="GlowBg" Background="#FEF3C7" Opacity="0" CornerRadius="12" Margin="0,2"/>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="12" Padding="{TemplateBinding Padding}" Margin="0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="NeonIndicator" Grid.Column="0" Width="4" Height="20"
                                            Background="{DynamicResource AccentPrimary}" CornerRadius="2" Margin="-8,0,12,0"
                                            Opacity="0" Effect="{StaticResource GlowGreen}"/>
                                    <ContentPresenter Grid.Column="1" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F0FDF4"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentPrimary}"/>
                                <Setter TargetName="NeonIndicator" Property="Opacity" Value="1"/>
                                <Setter TargetName="GlowBg" Property="Opacity" Value="0.6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#DCFCE7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Button for Logs (Soft Pink Hover) -->
        <Style x:Key="SidebarLogButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Poppins"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="GlowBg" Background="#FCE7F3" Opacity="0" CornerRadius="12" Margin="0,2"/>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="12" Padding="{TemplateBinding Padding}" Margin="0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="NeonIndicator" Grid.Column="0" Width="4" Height="20"
                                            Background="#F472B6" CornerRadius="2" Margin="-8,0,12,0"
                                            Opacity="0" Effect="{StaticResource GlowPurple}"/>
                                    <ContentPresenter Grid.Column="1" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FDF2F8"/>
                                <Setter Property="Foreground" Value="#F472B6"/>
                                <Setter TargetName="NeonIndicator" Property="Opacity" Value="1"/>
                                <Setter TargetName="GlowBg" Property="Opacity" Value="0.6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FCE7F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Button for Suppliers (Pastel Blue Hover) -->
        <Style x:Key="SidebarSupplierButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Poppins"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="GlowBg" Background="#DBEAFE" Opacity="0" CornerRadius="12" Margin="0,2"/>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="12" Padding="{TemplateBinding Padding}" Margin="0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="Indicator" Grid.Column="0" Width="4" Height="20"
                                            Background="#3B82F6" CornerRadius="2" Margin="-8,0,12,0" Opacity="0"/>
                                    <ContentPresenter Grid.Column="1" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                                <Setter Property="Foreground" Value="#3B82F6"/>
                                <Setter TargetName="Indicator" Property="Opacity" Value="1"/>
                                <Setter TargetName="GlowBg" Property="Opacity" Value="0.6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Button for Settings (Pastel Yellow Hover) -->
        <Style x:Key="SidebarSettingsButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Poppins"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="GlowBg" Background="#FEF3C7" Opacity="0" CornerRadius="12" Margin="0,2"/>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="12" Padding="{TemplateBinding Padding}" Margin="0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="Indicator" Grid.Column="0" Width="4" Height="20"
                                            Background="#F59E0B" CornerRadius="2" Margin="-8,0,12,0" Opacity="0"/>
                                    <ContentPresenter Grid.Column="1" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FFFBEB"/>
                                <Setter Property="Foreground" Value="#F59E0B"/>
                                <Setter TargetName="Indicator" Property="Opacity" Value="1"/>
                                <Setter TargetName="GlowBg" Property="Opacity" Value="0.6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FEF3C7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Test / Demo Button -->
        <Style x:Key="TestButton" TargetType="Button">
            <Setter Property="Background" Value="#FDBA74"/>
            <Setter Property="Foreground" Value="#7C2D12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Poppins"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="0" CornerRadius="18" Padding="{TemplateBinding Padding}"
                                Effect="{StaticResource GlowOrange}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FED7AA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FDBA74"/>
                                <Setter TargetName="Bd" Property="Effect" Value="{x:Null}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
