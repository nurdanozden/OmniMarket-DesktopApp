<UserControl x:Class="OmniMarket.Views.SupplierDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,2"/>
        </Style>
        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Margin"      Value="0,0,0,14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource CorpBackground}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ── Header / Geri ── -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="← Geri" Command="{Binding GoBackCommand}"
                            Style="{StaticResource SecondaryButton}" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Tedarikçi Detayı" FontSize="26" FontWeight="Bold"
                                   FontFamily="Segoe UI" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Portföy, cari hesap ve güvenilirlik analizi"
                                   FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,3,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- ── Üst Panel: Tedarikçi Profil + Güvenilirlik Skoru ── -->
                <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                        CornerRadius="16" Padding="24" Margin="0,0,0,18"
                        Effect="{StaticResource CardShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <Border Width="60" Height="60" Background="{StaticResource CorpBlueSoft}"
                                CornerRadius="14" Margin="0,0,20,0" VerticalAlignment="Top">
                            <TextBlock Text="⊞" FontSize="30" Foreground="{StaticResource CorpBlue}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Tedarikçi Bilgileri -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SupplierName}" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Border Background="{StaticResource CorpBlueSoft}" CornerRadius="6"
                                        Padding="8,4" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding SupplierCategory}"
                                               Foreground="{StaticResource CorpBlue}" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="{StaticResource CorpEmeraldSoft}" CornerRadius="6"
                                        Padding="8,4" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding SupplierDays}"
                                               Foreground="{StaticResource CorpEmerald}" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#EDE9FE" CornerRadius="6" Padding="8,4">
                                    <TextBlock Text="{Binding ActiveOrderCount}"
                                               Foreground="#6D28D9" FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- Güvenilirlik Skoru Paneli -->
                        <Border Grid.Column="2" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                CornerRadius="12" Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Güvenilirlik Skoru" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                    <Border Background="{Binding ReliabilityColor, Converter={StaticResource HexToBrush}}"
                                            CornerRadius="6" Padding="8,3" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding ReliabilityLabel}" Foreground="#FFFFFF"
                                                   FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding ReliabilityScore, StringFormat={}{0:N0}}"
                                               FontSize="32" FontWeight="Bold"
                                               Foreground="{Binding ReliabilityColor, Converter={StaticResource HexToBrush}}"/>
                                    <TextBlock Text="/100" FontSize="16" Foreground="{StaticResource TextMuted}"
                                               VerticalAlignment="Bottom" Margin="4,0,0,6"/>
                                </StackPanel>
                                <!-- Progress Bar -->
                                <ProgressBar Value="{Binding ReliabilityScore}" Maximum="100"
                                             Height="8" Background="#E2E8F0"
                                             Foreground="{Binding ReliabilityColor, Converter={StaticResource HexToBrush}}"
                                             BorderThickness="0"/>
                                <TextBlock Text="{Binding WasteRateText, StringFormat=Zayiat Oranı: {0}}"
                                           FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── İki Kolon: Sol İletişim + Sağ Finansal ── -->
                <Grid Grid.Row="2" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sol Kolon: İletişim Bilgileri -->
                    <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="14" Padding="22" Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="{StaticResource CorpBlueSoft}" CornerRadius="8"
                                        Padding="8" Margin="0,0,12,0">
                                    <TextBlock Text="◉" FontSize="16" Foreground="{StaticResource CorpBlue}"/>
                                </Border>
                                <TextBlock Text="İletişim Bilgileri" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="TELEFON" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Text="{Binding SupplierPhone}" Style="{StaticResource InfoValue}"
                                       FontWeight="SemiBold" Foreground="{StaticResource CorpEmerald}"/>

                            <TextBlock Text="YETKİLİ KİŞİ" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Text="{Binding SupplierAuthorizedName}" Style="{StaticResource InfoValue}"/>

                            <TextBlock Text="ADRES" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Text="{Binding SupplierAddress}" Style="{StaticResource InfoValue}"/>

                            <TextBlock Text="TESLİMAT GÜNLERİ" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Text="{Binding SupplierDays}" Style="{StaticResource InfoValue}"/>

                            <!-- Harita Placeholder -->
                            <Border Background="#F1F5F9" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="10" Height="100">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="◎" FontSize="28" Foreground="#94A3B8"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Harita Görünümü" FontSize="12"
                                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Sağ Kolon: Cari Hesap -->
                    <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="14" Padding="22" Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Background="{StaticResource CorpEmeraldSoft}" CornerRadius="8"
                                        Padding="8" Margin="0,0,12,0">
                                    <TextBlock Text="₺" FontSize="16" Foreground="{StaticResource CorpEmerald}"
                                               FontWeight="Bold"/>
                                </Border>
                                <TextBlock Text="Cari Hesap" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Toplam Maliyet -->
                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="10" Padding="16" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Toplam Ürün Tutarı" Foreground="{StaticResource TextMuted}" FontSize="12"/>
                                    <TextBlock Grid.Column="1" Foreground="{StaticResource TextPrimary}"
                                               FontSize="15" FontWeight="Bold">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:N0} ₺">
                                                <Binding Path="TotalCost"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <!-- Ödenen -->
                            <Border Background="{StaticResource CorpEmeraldSoft}" BorderBrush="#A7F3D0" BorderThickness="1"
                                    CornerRadius="10" Padding="16" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="✓ Ödenen" Foreground="{StaticResource CorpEmerald}" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Foreground="{StaticResource CorpEmerald}"
                                               FontSize="15" FontWeight="Bold">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:N0} ₺">
                                                <Binding Path="PaidAmount"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <!-- Kalan Borç -->
                            <Border Background="{StaticResource CorpAmberSoft}" BorderBrush="#FDE68A" BorderThickness="1"
                                    CornerRadius="10" Padding="16" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="! Kalan Borç" Foreground="{StaticResource CorpAmber}" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Foreground="{StaticResource CorpAmber}"
                                               FontSize="15" FontWeight="Bold">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0:N0} ₺">
                                                <Binding Path="RemainingDebt"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <!-- Toplam Ürün + Zayiat -->
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                        CornerRadius="10" Padding="14,10" Margin="0,0,8,0" Width="110">
                                    <StackPanel>
                                        <TextBlock Text="Ürün Çeşidi" FontSize="10" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding TotalProductCount}" FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimary}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="{StaticResource CorpRedSoft}" BorderBrush="#FECACA" BorderThickness="1"
                                        CornerRadius="10" Padding="14,10">
                                    <StackPanel>
                                        <TextBlock Text="Zayiat" FontSize="10" Foreground="{StaticResource CorpRed}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding WasteRateText}" FontSize="20" FontWeight="Bold"
                                                   Foreground="{StaticResource CorpRed}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── Ürün Portföyü Tablosu ── -->
                <Border Grid.Row="3" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                        CornerRadius="16" Padding="24" Effect="{StaticResource CardShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Background="{StaticResource CorpBlueSoft}" CornerRadius="8"
                                    Padding="8" Margin="0,0,12,0">
                                <TextBlock Text="◫" FontSize="18" Foreground="{StaticResource CorpBlue}"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Ürün Portföyü" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Bu tedarikçiden alınan tüm ürünler — stok ve SKT durumu"
                                           FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Products}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserSortColumns="True"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#F1F5F9"
                                  RowBackground="#FFFFFF" AlternatingRowBackground="#FAFAFA"
                                  BorderThickness="0" Background="Transparent"
                                  MaxHeight="400">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"   Value="#F8FAFC"/>
                                    <Setter Property="Foreground"   Value="#64748B"/>
                                    <Setter Property="FontWeight"   Value="SemiBold"/>
                                    <Setter Property="FontSize"     Value="11"/>
                                    <Setter Property="Padding"      Value="12,10"/>
                                    <Setter Property="BorderBrush"  Value="#E2E8F0"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </Style>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding"         Value="12,8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FontFamily"      Value="Segoe UI"/>
                                    <Setter Property="FontSize"        Value="13"/>
                                    <Setter Property="Foreground"      Value="#0F172A"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Ürün Adı"     Binding="{Binding Name}"     Width="*"   MinWidth="140"/>
                                <DataGridTextColumn Header="Kategori"     Binding="{Binding Category}" Width="120"/>
                                <DataGridTextColumn Header="Stok"         Binding="{Binding Stock}"    Width="70"/>
                                <DataGridTextColumn Header="Alış Fiyatı"  Binding="{Binding PurchasePrice, StringFormat={}{0:N2} ₺}" Width="120"/>
                                <DataGridTextColumn Header="Toplam Değer" Binding="{Binding TotalValue, StringFormat={}{0:N0} ₺}"     Width="130"/>
                                <DataGridTextColumn Header="SKT"          Binding="{Binding ExpiryDateText}" Width="100"/>
                                <DataGridTemplateColumn Header="Durum" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="8,4" Margin="6,4" HorizontalAlignment="Left"
                                                    Background="{Binding StatusColor, Converter={StaticResource HexToBrush}}">
                                                <TextBlock Text="{Binding StatusText}" Foreground="#FFFFFF"
                                                           FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Grid.Row="1"
                                   Text="Bu tedarikçiye ait ürün bulunmuyor."
                                   Foreground="{StaticResource TextMuted}" FontSize="14" FontStyle="Italic"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding Products.Count, Converter={StaticResource ZeroToVisibility}}"/>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
