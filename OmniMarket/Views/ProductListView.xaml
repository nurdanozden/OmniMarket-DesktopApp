<UserControl x:Class="OmniMarket.Views.ProductListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:OmniMarket.Helpers">

    <Grid>
        <!-- Cute Vibrant Background Gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFEDFA" Offset="0"/>
                <GradientStop Color="#FFF2E8" Offset="0.5"/>
                <GradientStop Color="#EAF2FF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Blobs for "Süslü" look -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="400" Height="400" Fill="#FFD1E8" Opacity="0.5" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-100,-100,0,0">
                <Ellipse.Effect><BlurEffect Radius="80"/></Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="500" Height="500" Fill="#D1E8FF" Opacity="0.5" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-150,-150">
                <Ellipse.Effect><BlurEffect Radius="100"/></Ellipse.Effect>
            </Ellipse>
        </Grid>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Ürün Yönetimi 🎀" FontSize="32" FontWeight="Heavy" FontFamily="Comic Sans MS, Segoe UI Print, Segoe UI" Foreground="#EC4899"/>
                <TextBlock Text="Depo ürünlerinizi neşeyle yönetin ✨" FontSize="15" Foreground="#9CA3AF" FontWeight="SemiBold" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="🛒 + Yeni Ürün" Command="{Binding AddProductCommand}"
                        Style="{StaticResource CuteButton}" Width="150" Margin="0,0,8,0">
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="15" Color="#F472B6" ShadowDepth="4" Opacity="0.4"/>
                    </Button.Effect>
                </Button>
                <Button Content="✎ Düzenle" Command="{Binding EditProductCommand}"
                        Style="{StaticResource WarningButton}" Width="120" Margin="0,0,8,0"/>
                <Button Content="🗑 Sil" Command="{Binding DeleteProductCommand}"
                        Style="{StaticResource DangerButton}" Width="90"/>
            </StackPanel>
        </Grid>

        <!-- Search / Filter Bar -->
        <TextBlock Grid.Row="1" Text="{Binding ActiveFilterLabel}" 
                   Foreground="{DynamicResource AccentBlue}" FontSize="13" FontWeight="SemiBold"
                   Margin="0,0,0,8"
                   Visibility="{Binding ActiveFilterLabel, Converter={StaticResource StringToVisibility}}"/>

        <Border Grid.Row="1" Style="{StaticResource GlassmorphismPanel}" Padding="16" Margin="0,28,0,16"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}"
                         Tag="🔍 Ürün adı veya barkod ile ara..." Margin="0,0,12,0"/>

                <ComboBox Grid.Column="1" ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}"
                          Style="{StaticResource ModernComboBox}" Margin="0,0,12,0"/>

                <Button Grid.Column="2" Content="✕ Temizle" Command="{Binding ClearFilterCommand}"
                        Style="{StaticResource SmallButton}"/>
            </Grid>
        </Border>

        <!-- Header Row for List -->
        <Border Grid.Row="2" Style="{StaticResource GlassmorphismPanel}" Padding="12,8" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Ürün" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" Text="Kategori" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="2" Text="Barkod" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="3" Text="Stok" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="4" Text="Alış ₺" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="5" Text="Satış ₺" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="6" Text="SKT" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="7" Text="Kar ₺" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold"/>
                <Grid Grid.Column="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Durum" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="Tedarikçi" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Product List -->
        <ListBox Grid.Row="3" ItemsSource="{Binding Products}"
                 SelectedItem="{Binding SelectedProduct}"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,12"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="18">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="#E0F2FE"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="#F0F9FF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource GlassmorphismPanel}" Padding="14" Margin="0,0,0,0"
                            Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <Border Background="#DBEAFE" CornerRadius="10" Padding="6" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding Category, Converter={StaticResource CategoryEmoji}}" FontSize="14"/>
                                </Border>
                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding Category}" Foreground="{StaticResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding Barcode}" Foreground="{StaticResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{Binding Stock}" Foreground="{StaticResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="{Binding PurchasePrice, StringFormat=N2}" Foreground="{StaticResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="{Binding SalePrice, StringFormat=N2}" Foreground="{StaticResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="{Binding ExpiryDate, StringFormat=dd.MM.yyyy}" Foreground="{StaticResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="7" Text="{Binding Profit, StringFormat=N2}" Foreground="{StaticResource TextPrimary}" FontSize="13" VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="8" VerticalAlignment="Center" Orientation="Horizontal">
                                <Border x:Name="StatusBadge" Background="#DCFCE7" CornerRadius="20" Padding="10,4">
                                    <TextBlock Text="{Binding ExpiryStatus, Converter={StaticResource ExpiryStatusText}}"
                                               Foreground="{Binding ExpiryStatus, Converter={StaticResource ExpiryStatusColor}}"
                                               FontWeight="SemiBold" FontSize="11"/>
                                </Border>
                                <StackPanel x:Name="SupplierPhonePanel" Orientation="Horizontal" Visibility="Collapsed" Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="📞 " FontSize="12" Foreground="#10B981" Margin="0,0,2,0"/>
                                    <TextBlock Text="{Binding Tedarikci.IletisimNo}" 
                                               Foreground="#10B981" FontSize="11" FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding ExpiryStatus}" Value="Expired">
                            <Setter TargetName="StatusBadge" Property="Background" Value="#FCE7F3"/>
                            <Setter TargetName="SupplierPhonePanel" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ExpiryStatus}" Value="Warning">
                            <Setter TargetName="StatusBadge" Property="Background" Value="#FEF3C7"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ExpiryStatus}" Value="Normal">
                            <Setter TargetName="StatusBadge" Property="Background" Value="#DCFCE7"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Inline Form (Add/Edit) -->
        <Border Grid.Row="4" Style="{StaticResource GlassmorphismPanel}" Padding="20" Margin="0,16,0,0"
                Effect="{StaticResource CardShadow}"
                Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <TextBlock Text="{Binding FormTitle}" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 1 -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                        <TextBlock Text="Ürün Adı *" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <!-- Kategori â†’ ComboBox -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,4,12">
                        <TextBlock Text="Kategori *" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding FormCategories}"
                                  SelectedItem="{Binding FormCategory}"
                                  Style="{StaticResource ModernComboBox}"/>
                    </StackPanel>

                    <!-- Barkod + Oluştur butonu -->
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="4,0,4,12">
                        <TextBlock Text="Barkod" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding FormBarcode, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"/>
                            <Button Grid.Column="1" Content="🔄"
                                    Command="{Binding GenerateBarcodeCommand}"
                                    ToolTip="Otomatik barkod oluştur"
                                    Style="{StaticResource SmallButton}" Margin="4,0,0,0"
                                    VerticalAlignment="Stretch" Padding="10,8"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="8,0,0,12">
                        <TextBlock Text="Stok *" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FormStock, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>

                    <!-- Row 2 -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,12">
                        <TextBlock Text="Alış Fiyatı (₺) *" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FormPurchasePrice, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="4,0,4,12">
                        <TextBlock Text="Satış Fiyatı (₺) *" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding FormSalePrice, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ModernTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="4,0,4,12">
                        <TextBlock Text="Son Kullanma Tarihi *" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                        <DatePicker SelectedDate="{Binding FormExpiryDate}"
                                    Style="{StaticResource ModernDatePicker}"/>
                    </StackPanel>

                    <!-- Row 3: Buttons -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4"
                                Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                        <Button Content="İptal" Command="{Binding CancelFormCommand}"
                                Style="{StaticResource SecondaryButton}" Width="100" Margin="0,0,8,0"/>
                        <Button Content="💾 Kaydet" Command="{Binding SaveProductCommand}"
                                Style="{StaticResource SuccessButton}" Width="120"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
        </Grid>
    </Grid>
</UserControl>
