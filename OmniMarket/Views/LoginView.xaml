<UserControl x:Class="OmniMarket.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OmniMarket.ViewModels">
    <UserControl.DataContext>
        <vm:LoginViewModel/>
    </UserControl.DataContext>

    <Grid Background="#0f172a">
        <Border Background="#1e293b" CornerRadius="16" Padding="40"
                Width="480" VerticalAlignment="Center" HorizontalAlignment="Center"
                Effect="{StaticResource CardShadow}">
            <StackPanel>
                <!-- Logo / Title -->
                <TextBlock Text="🛒" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="OmniMarket" FontSize="28" FontWeight="Bold"
                           Foreground="#f8fafc" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Akıllı Market Depo Yönetimi" FontSize="13"
                           Foreground="#94a3b8" HorizontalAlignment="Center" Margin="0,0,0,28"/>

                <!-- Kullanıcı Adı -->
                <TextBlock Text="Kullanıcı Adı" Foreground="#94a3b8" FontSize="12" Margin="0,0,0,6"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                <!-- Şifre -->
                <TextBlock Text="Şifre" Foreground="#94a3b8" FontSize="12" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,8"/>

                <!-- Hata Mesajı -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#ef4444"
                           FontSize="12" Margin="0,0,0,16" TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

                <!-- Giriş Butonu -->
                <Button Content="Giriş Yap" Command="{Binding LoginCommand}"
                        Style="{StaticResource PrimaryButton}" Margin="0,0,0,16"/>

                <!-- Kayıt Linki -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock Text="Hesabınız yok mu? " Foreground="#94a3b8" FontSize="12"/>
                    <TextBlock FontSize="12">
                        <Hyperlink Command="{Binding GoToRegisterCommand}"
                                   Foreground="#3b82f6" TextDecorations="None">
                            Kayıt Ol
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>

                <!-- Ayırıcı -->
                <Border Height="1" Background="#334155" Margin="0,0,0,16"/>

                <!-- Test Giriş Butonu -->
                <Button Content="🚀 Test Giriş (NUR MARKET)"
                        Command="{Binding TestLoginCommand}"
                        ToolTip="Demo verilerle hızlı giriş yap"
                        Style="{StaticResource TestButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
