<UserControl x:Class="OmniMarket.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OmniMarket.ViewModels">
    
    <UserControl.DataContext>
        <vm:LoginViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <!-- Fade-in/Slide-up Login Animation -->
        <Storyboard x:Key="FadeInAnim">
            <DoubleAnimation Storyboard.TargetName="MainCard" 
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainCard" 
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="30" To="0" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeInAnim}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <!-- Dark Professional Corporate Background -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F172A" Offset="0"/>   <!-- Slate 900 -->
                <GradientStop Color="#1E293B" Offset="0.6"/> <!-- Slate 800 -->
                <GradientStop Color="#0B1120" Offset="1"/>   <!-- Navy Dark -->
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Subtle Background Pattern/Glow overlay -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="800" Height="800" Fill="#1D4ED8" Opacity="0.10" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-250,-250,0,0">
                <Ellipse.Effect><BlurEffect Radius="150"/></Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="600" Height="600" Fill="#059669" Opacity="0.08" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-150,-150">
                <Ellipse.Effect><BlurEffect Radius="120"/></Ellipse.Effect>
            </Ellipse>
        </Grid>

        <!-- Main Login Card Container -->
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
            
            <!-- Modern Enterprise Card -->
            <Border x:Name="MainCard" Width="420" Background="#FFFFFF" CornerRadius="16" Padding="40"
                    BorderBrush="#E2E8F0" BorderThickness="1" Opacity="0">
                <Border.RenderTransform>
                    <TranslateTransform Y="30"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" Color="#000000" ShadowDepth="10" Opacity="0.4"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Logo & Brand -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <Border Background="{StaticResource CorpSidebar}" Width="40" Height="40" CornerRadius="8" Margin="0,0,12,0"
                                Effect="{StaticResource GlowBlue}">
                            <TextBlock Text="OM" Foreground="#FFFFFF" FontWeight="Bold" FontSize="16" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="OmniMarket" FontSize="28" FontWeight="Bold" 
                                   FontFamily="Segoe UI" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Kurumsal Stok ve Sipariş Yönetimi" FontSize="13" 
                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,32"/>

                    <!-- Kullanıcı Adı -->
                    <TextBlock Text="KULLANICI ADI" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}" 
                             Tag="Kurumsal sicil veya e-posta" Margin="0,0,0,20"/>

                    <!-- Şifre -->
                    <TextBlock Text="ŞİFRE" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,24">
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource ModernPasswordBox}"/>
                        <TextBlock x:Name="PasswordPlaceholder" Text="Sistem şifreniz" 
                                   Foreground="#94A3B8" FontSize="13" FontFamily="Segoe UI"
                                   VerticalAlignment="Center" Margin="13,0,0,0"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Hata Mesajı -->
                    <Border Background="{StaticResource CorpRedSoft}" CornerRadius="8" Padding="12" Margin="0,0,0,20"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="⚠ " Foreground="{StaticResource CorpRed}"/>
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource CorpRed}"
                                       FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <!-- Giriş Butonu -->
                    <Button Content="Sisteme Giriş Yap" Command="{Binding LoginCommand}"
                            Style="{StaticResource SuccessButton}" FontSize="14" Padding="0,12" Margin="0,0,0,24">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="12" Color="#059669" ShadowDepth="4" Opacity="0.3"/>
                        </Button.Effect>
                    </Button>

                    <!-- Kayıt Linki -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                        <TextBlock Text="İlk defa mı giriş yapıyorsunuz? " Foreground="{StaticResource TextMuted}" FontSize="13"/>
                        <TextBlock FontSize="13" FontWeight="SemiBold">
                            <Hyperlink Command="{Binding GoToRegisterCommand}"
                                       Foreground="{StaticResource CorpBlue}" TextDecorations="None">
                                Kullanıcı Oluşturun
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>

                    <!-- Ayırıcı -->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Height="1" Background="#E2E8F0"/>
                        <TextBlock Grid.Column="1" Text="GELİŞTİRİCİ ERİŞİMİ" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="11" Margin="12,0"/>
                        <Border Grid.Column="2" Height="1" Background="#E2E8F0"/>
                    </Grid>

                    <!-- Test Giriş Butonu -->
                    <Button Content="Hızlı Demo Girişi (Admin: NUR MARKET)"
                            Command="{Binding TestLoginCommand}"
                            ToolTip="Demoyu kurumsal ayarlar ile test et"
                            Style="{StaticResource SecondaryButton}" 
                            FontSize="13" Padding="0,10"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>


