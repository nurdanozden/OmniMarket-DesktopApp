<UserControl x:Class="OmniMarket.Views.SupplierListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource CorpBackground}">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Tedarikçiler" FontSize="28" FontWeight="Bold"
                               FontFamily="Segoe UI" Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Tedarikçi ilişkilerini ve portföyleri yönetin"
                               FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="+ Yeni" Command="{Binding AddSupplierCommand}"
                            Style="{StaticResource PrimaryButton}" Width="100" Margin="0,0,8,0"/>
                    <Button Content="Düzenle" Command="{Binding EditSupplierCommand}"
                            Style="{StaticResource WarningButton}" Width="100" Margin="0,0,8,0"/>
                    <Button Content="Sil" Command="{Binding DeleteSupplierCommand}"
                            Style="{StaticResource DangerButton}" Width="80"/>
                </StackPanel>
            </Grid>

            <!-- Supplier List -->
            <ListBox Grid.Row="1" ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin"  Value="0,0,0,10"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder" Background="Transparent" CornerRadius="12">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#EFF6FF"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#F8FAFC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                                CornerRadius="12" Padding="16" Effect="{StaticResource CardShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Icon -->
                                <Border Width="44" Height="44" Background="{StaticResource CorpBlueSoft}"
                                        CornerRadius="10" Margin="0,0,14,0">
                                    <TextBlock Text="⊞" FontSize="20" Foreground="{StaticResource CorpBlue}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Ad}" Foreground="{StaticResource TextPrimary}"
                                               FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Kategori}" Foreground="{StaticResource TextMuted}"
                                               FontSize="12" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding TeslimatGunleri}" Foreground="{StaticResource TextMuted}"
                                               FontSize="12"/>
                                </StackPanel>

                                <!-- Phone badge -->
                                <Border Grid.Column="2" Background="{StaticResource CorpEmeraldSoft}"
                                        CornerRadius="8" Padding="12,6" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding IletisimNo}" Foreground="{StaticResource CorpEmerald}"
                                               FontWeight="SemiBold" FontSize="13"/>
                                </Border>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Inline Form -->
            <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                    CornerRadius="14" Padding="22" Margin="0,16,0,0"
                    Effect="{StaticResource CardShadow}"
                    Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="{Binding FormTitle}" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                            <TextBlock Text="Tedarikçi Adı" Foreground="{StaticResource TextMuted}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding FormAd}" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,0,12">
                            <TextBlock Text="İletişim No" Foreground="{StaticResource TextMuted}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding FormIletisimNo}" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,12">
                            <TextBlock Text="Teslimat Günleri" Foreground="{StaticResource TextMuted}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding FormTeslimatGunleri}" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="4,0,0,12">
                            <TextBlock Text="Kategori" Foreground="{StaticResource TextMuted}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding FormKategori}" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                            <Button Content="İptal" Command="{Binding CancelFormCommand}"
                                    Style="{StaticResource SecondaryButton}" Width="90" Margin="0,0,8,0"/>
                            <Button Content="Kaydet" Command="{Binding SaveSupplierCommand}"
                                    Style="{StaticResource SuccessButton}" Width="110"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
