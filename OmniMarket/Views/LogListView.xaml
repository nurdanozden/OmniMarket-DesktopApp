<UserControl x:Class="OmniMarket.Views.LogListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OmniMarket.ViewModels"
             xmlns:models="clr-namespace:OmniMarket.Models"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="960"
             Background="Transparent">
    
    <UserControl.Resources>
        <!-- Arama kutusu stili (Pastel Mavi) -->
        <Style x:Key="SearchTextBox" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3B82F6"/>
                    <Setter Property="Effect" Value="{StaticResource GlowBlue}"/>
                    <Setter Property="Background" Value="#F8FAFC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Timeline Node Template -->
        <DataTemplate x:Key="LogItemTemplate" DataType="{x:Type models:Log}">
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <!-- Sol: Zaman Çizgisi ve Nokta -->
                    <ColumnDefinition Width="60"/>
                    <!-- Sağ: İçerik Kartı -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Dikey Çizgi ve Nokta -->
                <Grid Grid.Column="0">
                    <Rectangle Width="3" Fill="#FCD34D" HorizontalAlignment="Center" VerticalAlignment="Stretch" Margin="0,20,0,-24"/>
                    
                    <!-- Parlayan Daire (Renk DataTrigger ile değişecek) -->
                    <Border x:Name="NodeCircle" Width="18" Height="18" CornerRadius="9" 
                            Background="#10B981" BorderBrush="#FFFFFF" BorderThickness="2"
                            HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,24,0,0"
                            Effect="{StaticResource GlowGreen}"/>
                </Grid>

                <!-- İçerik Kartı (Glassmorphism) -->
                <Border Grid.Column="1" Style="{StaticResource GlassmorphismPanel}" Padding="20" Margin="0,0,24,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- İşlem İkonu -->
                        <Border x:Name="TypeIcon" Background="#DBEAFE" CornerRadius="10" Padding="8" Margin="0,0,12,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TypeIconText" Text="🏷" FontSize="14"/>
                        </Border>

                        <!-- İşlem Tipi Başlığı ve Kullanıcı -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,20,0" MinWidth="120">
                            <TextBlock Text="{Binding IslemTipi}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="{Binding KullaniciAdi}" FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Detay -->
                        <TextBlock Grid.Column="2" Text="{Binding Detay}" FontSize="13" Foreground="{StaticResource TextPrimary}" 
                                   TextWrapping="Wrap" VerticalAlignment="Center"/>

                        <!-- Tarih -->
                        <TextBlock Grid.Column="3" Text="{Binding Tarih, StringFormat='dd MMM yyyy HH:mm'}" 
                                   FontSize="12" Foreground="{StaticResource TextMuted}" VerticalAlignment="Top" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- Kayarak gelme animasyonu -->
                <Grid.Triggers>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <ThicknessAnimation Storyboard.TargetProperty="Margin"
                                                    From="0,50,0,0" To="0,0,0,24" Duration="0:0:0.6">
                                    <ThicknessAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </ThicknessAnimation.EasingFunction>
                                </ThicknessAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0" To="1" Duration="0:0:0.6"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>
            </Grid>

            <!-- DataTriggers to change the glowing node color based on LogType -->
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IslemTipi}" Value="Ekleme">
                    <Setter TargetName="NodeCircle" Property="Background" Value="#10B981"/>
                    <Setter TargetName="NodeCircle" Property="Effect" Value="{StaticResource GlowGreen}"/>
                    <Setter TargetName="TypeIcon" Property="Background" Value="#DCFCE7"/>
                    <Setter TargetName="TypeIconText" Property="Text" Value="➕"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IslemTipi}" Value="Silme">
                    <Setter TargetName="NodeCircle" Property="Background" Value="#F472B6"/>
                    <Setter TargetName="NodeCircle" Property="Effect" Value="{StaticResource GlowRed}"/>
                    <Setter TargetName="TypeIcon" Property="Background" Value="#FCE7F3"/>
                    <Setter TargetName="TypeIconText" Property="Text" Value="🗑"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IslemTipi}" Value="Guncelleme">
                    <Setter TargetName="NodeCircle" Property="Background" Value="#3B82F6"/>
                    <Setter TargetName="NodeCircle" Property="Effect" Value="{StaticResource GlowBlue}"/>
                    <Setter TargetName="TypeIcon" Property="Background" Value="#DBEAFE"/>
                    <Setter TargetName="TypeIconText" Property="Text" Value="🏷"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IslemTipi}" Value="Login">
                    <Setter TargetName="NodeCircle" Property="Background" Value="#A78BFA"/>
                    <Setter TargetName="NodeCircle" Property="Effect" Value="{StaticResource GlowPurple}"/>
                    <Setter TargetName="TypeIcon" Property="Background" Value="#EDE9FE"/>
                    <Setter TargetName="TypeIconText" Property="Text" Value="🔐"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <!-- Cute Vibrant Background Gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFEDFA" Offset="0"/>
                <GradientStop Color="#FFF2E8" Offset="0.5"/>
                <GradientStop Color="#EAF2FF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Blobs for "Süslü" look -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="400" Height="400" Fill="#FFD1E8" Opacity="0.5" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-100,-100,0,0">
                <Ellipse.Effect><BlurEffect Radius="80"/></Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="500" Height="500" Fill="#D1E8FF" Opacity="0.5" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-150,-150">
                <Ellipse.Effect><BlurEffect Radius="100"/></Ellipse.Effect>
            </Ellipse>
        </Grid>

        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header ve Arama -->
            <Border Grid.Row="0" Style="{StaticResource GlassmorphismPanel}" Padding="24" Margin="0,0,0,24" Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="İşlem Geçmişi 🌸" FontSize="32" FontWeight="Heavy" FontFamily="Comic Sans MS, Segoe UI Print, Segoe UI" Foreground="#EC4899"/>
                        <TextBlock Text="Sistem üzerindeki tüm aktiviteleri sihirli günlüğünüzden takip edin ✨" FontSize="15" Foreground="#9CA3AF" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>

                <!-- Arama Kutusu (Live Search) -->
                <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource SearchTextBox}" Tag="Arama (Kullanıcı, İşlem...)" 
                         VerticalAlignment="Center"/>
            </Grid>
        </Border>

            <!-- Timeline Log Listesi -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding FilteredLogsView.View}" 
                              ItemTemplate="{StaticResource LogItemTemplate}"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
