<UserControl x:Class="OmniMarket.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OmniMarket.ViewModels">
    <UserControl.DataContext>
        <vm:RegisterViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <!-- Fade-in/Slide-up Login Animation -->
        <Storyboard x:Key="FadeInAnim">
            <DoubleAnimation Storyboard.TargetName="MainCard" 
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainCard" 
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="30" To="0" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeInAnim}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <!-- Dark Professional Corporate Background -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F172A" Offset="0"/>   <!-- Slate 900 -->
                <GradientStop Color="#1E293B" Offset="0.6"/> <!-- Slate 800 -->
                <GradientStop Color="#0B1120" Offset="1"/>   <!-- Navy Dark -->
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Subtle Background Pattern/Glow overlay -->
        <Grid IsHitTestVisible="False" ClipToBounds="True">
            <Ellipse Width="800" Height="800" Fill="#1D4ED8" Opacity="0.10" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-250,-250,0,0">
                <Ellipse.Effect><BlurEffect Radius="150"/></Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="600" Height="600" Fill="#059669" Opacity="0.08" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-150,-150">
                <Ellipse.Effect><BlurEffect Radius="120"/></Ellipse.Effect>
            </Ellipse>
        </Grid>

        <!-- Main Card Container -->
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
            
            <!-- Modern Enterprise Card -->
            <Border x:Name="MainCard" Width="450" Background="#FFFFFF" CornerRadius="16" Padding="40"
                    BorderBrush="#E2E8F0" BorderThickness="1" Opacity="0">
                <Border.RenderTransform>
                    <TranslateTransform Y="30"/>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" Color="#000000" ShadowDepth="10" Opacity="0.4"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Geri Dön Butonu -->
                    <Button Content="← Geri Dön" Command="{Binding GoToLoginCommand}"
                            Style="{StaticResource BaseButton}" Background="Transparent"
                            HorizontalAlignment="Left" Foreground="{StaticResource TextMuted}"
                            Padding="0" Margin="0,-20,0,10" FontSize="13" FontWeight="SemiBold"/>

                    <!-- Logo & Brand -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <Border Background="{StaticResource CorpSidebar}" Width="40" Height="40" CornerRadius="8" Margin="0,0,12,0"
                                Effect="{StaticResource GlowBlue}">
                            <TextBlock Text="OM" Foreground="#FFFFFF" FontWeight="Bold" FontSize="16" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Yeni Şube Kaydı" FontSize="28" FontWeight="Bold" 
                                   FontFamily="Segoe UI" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Sisteme yeni yönetici veya şube ekleyin" FontSize="13" 
                               Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,24"/>

                    <!-- Market Adı -->
                    <TextBlock Text="MARKET/ŞUBE ADI" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding MarketName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}" 
                             Tag="Kurumsal market veya şube adı" Margin="0,0,0,16"/>

                    <!-- Kullanıcı Adı -->
                    <TextBlock Text="KULLANICI ADI" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ModernTextBox}" 
                             Tag="Yönetici kullanıcı adı" Margin="0,0,0,16"/>

                    <!-- Şifre -->
                    <TextBlock Text="ŞİFRE" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,24">
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource ModernPasswordBox}"/>
                        <TextBlock x:Name="PasswordPlaceholder" Text="Şifre oluşturun"
                                   Foreground="#94A3B8" FontSize="13" FontFamily="Segoe UI"
                                   VerticalAlignment="Center" Margin="13,0,0,0"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Hata Mesajı -->
                    <Border Background="{StaticResource CorpRedSoft}" CornerRadius="8" Padding="12" Margin="0,0,0,16"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="⚠ " Foreground="{StaticResource CorpRed}"/>
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource CorpRed}"
                                       FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Başarı Mesajı -->
                    <Border Background="#D1FAE5" CornerRadius="8" Padding="12" Margin="0,0,0,16"
                            Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibility}}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="✓ " Foreground="#10B981" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SuccessMessage}" Foreground="#10B981"
                                       FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Kayıt Butonu -->
                    <Button Content="Hesabı Oluştur ve Başla" Command="{Binding RegisterCommand}"
                            Style="{StaticResource SuccessButton}" FontSize="14" Padding="0,12" Margin="0,0,0,20">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="12" Color="#059669" ShadowDepth="4" Opacity="0.3"/>
                        </Button.Effect>
                    </Button>

                    <!-- Giriş Linki -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <TextBlock Text="Zaten sisteme kayıtlı mısınız? " Foreground="{StaticResource TextMuted}" FontSize="13"/>
                        <TextBlock FontSize="13" FontWeight="SemiBold">
                            <Hyperlink Command="{Binding GoToLoginCommand}"
                                       Foreground="{StaticResource CorpBlue}" TextDecorations="None">
                                Giriş Yap
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
