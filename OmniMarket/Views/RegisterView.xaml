<UserControl x:Class="OmniMarket.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OmniMarket.ViewModels">
    <UserControl.DataContext>
        <vm:RegisterViewModel/>
    </UserControl.DataContext>

    <Grid Background="#0f172a">
        <Border Background="#1e293b" CornerRadius="16" Padding="40"
                Width="500" VerticalAlignment="Center" HorizontalAlignment="Center"
                Effect="{StaticResource CardShadow}">
            <StackPanel>
                <!-- Geri Dön Butonu -->
                <Button Content="← Geri Dön" Command="{Binding GoToLoginCommand}"
                        Style="{StaticResource SidebarButton}" 
                        HorizontalAlignment="Left" Foreground="#94a3b8" 
                        Padding="0" Margin="0,0,0,12" FontSize="13"/>
                        
                <!-- Title -->
                <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Yeni Market Kaydı" FontSize="24" FontWeight="Bold"
                           Foreground="#f8fafc" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Market bilgilerinizi girin" FontSize="13"
                           Foreground="#94a3b8" HorizontalAlignment="Center" Margin="0,0,0,28"/>

                <!-- Market Adı -->
                <TextBlock Text="Market Adı" Foreground="#94a3b8" FontSize="12" Margin="0,0,0,6"/>
                <TextBox Text="{Binding MarketName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                <!-- Kullanıcı Adı -->
                <TextBlock Text="Kullanıcı Adı" Foreground="#94a3b8" FontSize="12" Margin="0,0,0,6"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                <!-- Şifre -->
                <TextBlock Text="Şifre" Foreground="#94a3b8" FontSize="12" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,8"/>

                <!-- Hata Mesajı -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#ef4444"
                           FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

                <!-- Başarı Mesajı -->
                <TextBlock Text="{Binding SuccessMessage}" Foreground="#22c55e"
                           FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"
                           Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibility}}"/>

                <!-- Kayıt Butonu -->
                <Button Content="Kayıt Ol" Command="{Binding RegisterCommand}"
                        Style="{StaticResource SuccessButton}" Margin="0,8,0,16"/>

                <!-- Giriş Linki -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Zaten hesabınız var mı? " Foreground="#94a3b8" FontSize="12"/>
                    <TextBlock FontSize="12">
                        <Hyperlink Command="{Binding GoToLoginCommand}"
                                   Foreground="#3b82f6" TextDecorations="None">
                            Giriş Yap
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
