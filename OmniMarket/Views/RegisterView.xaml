<UserControl x:Class="OmniMarket.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OmniMarket.ViewModels">
    <UserControl.DataContext>
        <vm:RegisterViewModel/>
    </UserControl.DataContext>

    <Grid Background="{StaticResource SpaceBackground}">
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="260" Height="90" Fill="#FFFFFF" Opacity="0.7" Canvas.Left="140" Canvas.Top="80"/>
            <Ellipse Width="220" Height="80" Fill="#FFFFFF" Opacity="0.6" Canvas.Left="520" Canvas.Top="40"/>
        </Canvas>

        <Border Style="{StaticResource GlassmorphismPanel}" Padding="40"
                Width="500" VerticalAlignment="Center" HorizontalAlignment="Center"
                Effect="{StaticResource CardShadow}">
            <StackPanel>
                <!-- Geri Dön Butonu -->
                <Button Content="← Geri Dön" Command="{Binding GoToLoginCommand}"
                        Style="{StaticResource SidebarButton}"
                        HorizontalAlignment="Left" Foreground="{StaticResource TextMuted}"
                        Padding="0" Margin="0,0,0,12" FontSize="13"/>

                <!-- Title -->
                <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Yeni Market Kaydı" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Market bilgilerinizi girin" FontSize="13"
                           Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,28"/>

                <!-- Market Adı -->
                <TextBlock Text="Market Adı" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,6"/>
                <TextBox Text="{Binding MarketName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                <!-- Kullanıcı Adı -->
                <TextBlock Text="Kullanıcı Adı" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,6"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                <!-- Şifre -->
                <TextBlock Text="Şifre" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource ModernPasswordBox}" Margin="0,0,0,8"/>

                <!-- Hata Mesajı -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#F472B6"
                           FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

                <!-- Başarı Mesajı -->
                <TextBlock Text="{Binding SuccessMessage}" Foreground="#10B981"
                           FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"
                           Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibility}}"/>

                <!-- Kayıt Butonu -->
                <Button Content="Kayıt Ol" Command="{Binding RegisterCommand}"
                        Style="{StaticResource SuccessButton}" Margin="0,8,0,16"/>

                <!-- Giriş Linki -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Zaten hesabınız var mı? " Foreground="{StaticResource TextMuted}" FontSize="12"/>
                    <TextBlock FontSize="12">
                        <Hyperlink Command="{Binding GoToLoginCommand}"
                                   Foreground="{DynamicResource AccentBlue}" TextDecorations="None">
                            Giriş Yap
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
