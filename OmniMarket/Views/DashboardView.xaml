<UserControl x:Class="OmniMarket.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="Dashboard" FontSize="28" FontWeight="Bold" Foreground="#f8fafc"/>
                <TextBlock Text="Market durumunuza genel bakış" FontSize="14" Foreground="#94a3b8" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Stats Cards -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,24">
                <!-- Toplam Ürün -->
                <Border Background="#1e293b" CornerRadius="12" Padding="20" Margin="0,0,12,0"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="📦" FontSize="28" Margin="0,0,0,8"/>
                        <TextBlock Text="Toplam Ürün" Foreground="#94a3b8" FontSize="12"/>
                        <TextBlock Text="{Binding TotalProducts}" Foreground="#f8fafc" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- SKT Yaklaşan -->
                <Border Background="#1e293b" CornerRadius="12" Padding="20" Margin="6,0,6,0"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="⏰" FontSize="28" Margin="0,0,0,8"/>
                        <TextBlock Text="SKT Yaklaşan" Foreground="#94a3b8" FontSize="12"/>
                        <TextBlock Text="{Binding ExpiringProducts}" Foreground="#f59e0b" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- SKT Geçmiş -->
                <Border Background="#1e293b" CornerRadius="12" Padding="20" Margin="6,0,6,0"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="⚠" FontSize="28" Margin="0,0,0,8"/>
                        <TextBlock Text="SKT Geçmiş" Foreground="#94a3b8" FontSize="12"/>
                        <TextBlock Text="{Binding ExpiredProducts}" Foreground="#ef4444" FontSize="32" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Stok Değeri -->
                <Border Background="#1e293b" CornerRadius="12" Padding="20" Margin="12,0,0,0"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="💰" FontSize="28" Margin="0,0,0,8"/>
                        <TextBlock Text="Toplam Stok Değeri" Foreground="#94a3b8" FontSize="12"/>
                        <TextBlock Foreground="#22c55e" FontSize="26" FontWeight="Bold">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0:N2} ₺">
                                    <Binding Path="TotalStockValue"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Charts Row -->
            <Grid Grid.Row="2" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- En Çok Ziyan Olan – Bar Chart -->
                <Border Grid.Column="0" Background="#1e293b" CornerRadius="12" Padding="20"
                        Effect="{StaticResource CardShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="300"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="📊" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="En Çok Ziyan Olan Ürünler" FontSize="16" FontWeight="SemiBold"
                                       Foreground="#f8fafc" VerticalAlignment="Center"/>
                        </StackPanel>
                        <oxy:PlotView Grid.Row="1" Model="{Binding ExpiredChartModel}" Background="Transparent"/>
                    </Grid>
                </Border>

                <!-- En Çok Satılan – Pie Chart -->
                <Border Grid.Column="2" Background="#1e293b" CornerRadius="12" Padding="20"
                        Effect="{StaticResource CardShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="300"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="📈" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="En Çok Satılan Ürünler" FontSize="16" FontWeight="SemiBold"
                                       Foreground="#f8fafc" VerticalAlignment="Center"/>
                        </StackPanel>
                        <oxy:PlotView Grid.Row="1" Model="{Binding MostSoldChartModel}" Background="Transparent"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Alerts Panel -->
            <Border Grid.Row="3" Background="#1e293b" CornerRadius="12" Padding="20"
                    Effect="{StaticResource CardShadow}" MinHeight="150">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="🚨" FontSize="20" Margin="0,0,8,0"/>
                        <TextBlock Text="Akıllı Uyarılar" FontSize="18" FontWeight="SemiBold" Foreground="#f8fafc"
                                   VerticalAlignment="Center"/>
                        <Button Content="↻ Yenile" Command="{Binding RefreshCommand}"
                                Style="{StaticResource SmallButton}" Margin="16,0,0,0"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="250">
                        <ItemsControl ItemsSource="{Binding Alerts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0f172a" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding Message}" Foreground="#e2e8f0"
                                                   FontSize="13" TextWrapping="Wrap"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty State -->
                    <TextBlock Grid.Row="1" Text="✅ Şu an herhangi bir uyarı bulunmuyor."
                               Foreground="#64748b" FontSize="14" HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding Alerts.Count, Converter={StaticResource ZeroToVisibility}}"/>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
