<UserControl x:Class="OmniMarket.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="ThemeColorButton" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="13" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Ayarlar &amp; Profil" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Text="Market profil bilgilerinizi y&#246;netin" FontSize="14" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Profile Card -->
            <Border Grid.Row="1" Style="{StaticResource GlassmorphismPanel}" Padding="24" Margin="0,0,0,20"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="72" Height="72" CornerRadius="24" Background="#FEF3C7" Margin="0,0,16,0">
                        <TextBlock Text="&#x1F3EA;" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding MarketAdi}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Kasaba Market Profili" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Form -->
            <Border Grid.Row="2" Style="{StaticResource GlassmorphismPanel}" Padding="24" Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="Profil Bilgileri" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,12">
                            <TextBlock Text="Market Ad&#305; G&#252;ncelle" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding MarketAdi}" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,0,12">
                            <TextBlock Text="Eski Şifre" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="OldPasswordBox" Style="{StaticResource ModernPasswordBox}"
                                         PasswordChanged="OldPasswordBox_OnPasswordChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
                            <TextBlock Text="Adres Bilgisi" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Adres}" Style="{StaticResource ModernTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,12">
                            <TextBlock Text="Yeni Şifre" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="NewPasswordBox" Style="{StaticResource ModernPasswordBox}"
                                         PasswordChanged="NewPasswordBox_OnPasswordChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="4,0,0,12">
                            <TextBlock Text="Yeni Şifre Tekrar" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="ConfirmPasswordBox" Style="{StaticResource ModernPasswordBox}"
                                         PasswordChanged="ConfirmPasswordBox_OnPasswordChanged"/>
                        </StackPanel>

                        <!-- Tema Seçici Kaldırıldı -->

                        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Kaydet" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Width="120"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
